# Microsoft Foundry project endpoint
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project>

# Azure subscription, resource group, and Foundry account used for provisioning
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=<your-resource-group>
FOUNDRY_ACCOUNT_NAME=<your-foundry-account-name>
