# Keyless auth (recommended): leave AZURE_AI_VISION_KEY blank, run `az login`, and make
# sure your identity has the "Cognitive Services User" role on the resource.
# (Newer Foundry resources have API keys disabled by default.)
AZURE_AI_VISION_ENDPOINT=https://<your-resource-name>.cognitiveservices.azure.com
AZURE_AI_VISION_KEY=
