# Microsoft Foundry project endpoint and model deployment
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project>
MODEL_DEPLOYMENT_NAME=gpt-5.1

# Azure subscription and resource group for resource provisioning
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=<your-resource-group>
AZURE_LOCATION=eastus2

# Knowledge-base backing resources
STORAGE_ACCOUNT_NAME=<your-storage-account>
SEARCH_SERVICE_NAME=<your-search-service>
BLOB_CONTAINER_NAME=knowledge-source
SEARCH_INDEX_NAME=support-kb-index
SEARCH_DATA_SOURCE_NAME=support-kb-blob-source
SEARCH_INDEXER_NAME=support-kb-indexer
KNOWLEDGE_SOURCE_NAME=support-kb-source
KNOWLEDGE_BASE_NAME=support-kb

# Name of the Azure AI Search connection registered on the Foundry project so the
# knowledge base shows up in the portal's Knowledge (Foundry IQ) blade.
SEARCH_PROJECT_CONNECTION_NAME=support-kb-search

# Optional: only set this if your Foundry account lives in a different resource group
# than AZURE_RESOURCE_GROUP. Otherwise it is derived from FOUNDRY_PROJECT_ENDPOINT.
# FOUNDRY_PROJECT_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>
