# Foundry project endpoint — must include /api/projects/<project-name>
FOUNDRY_PROJECT_ENDPOINT="https://<hub-name>.services.ai.azure.com/api/projects/<project-name>"

# Full ARM resource ID of the Foundry project — used to create the RemoteTool connection.
# Find it in the Azure Portal on the Foundry project's Properties page.
FOUNDRY_PROJECT_RESOURCE_ID="/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.CognitiveServices/accounts/<foundry-hub>/projects/<project>"

# Name of the deployed model in your Foundry project
MODEL_DEPLOYMENT_NAME="gpt-5.1"

# Azure AI Search endpoint that hosts the knowledge base
SEARCH_SERVICE_ENDPOINT="https://<your-search-name>.search.windows.net"

# Optional: resource group of the search service above. Only set this if the search
# service lives in a different resource group than the Foundry project. When omitted,
# the notebook uses the project's resource group for the RBAC role assignment.
# SEARCH_SERVICE_RESOURCE_GROUP="<your-search-resource-group>"

# Name of the knowledge base (the Knowledge Base lab builds one named support-kb)
KNOWLEDGE_BASE_NAME="support-kb"

# Name to give the RemoteTool connection this notebook creates in your Foundry project
SEARCH_SERVICE_PROJECT_CONNECTION_NAME="support-kb-mcp"
